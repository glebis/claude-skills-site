---
import fs from "node:fs";
import path from "node:path";

const stemSpecs = [
  { name: "square", src: "/audio/hero/square-market.mp3", angle: 210, volume: 0.42 },
  { name: "clock", src: "/audio/hero/shop-clock.mp3", angle: 145, volume: 0.2 },
  { name: "wood", src: "/audio/hero/wood-creaks.mp3", angle: 230, volume: 0.22 },
  { name: "shelves", src: "/audio/hero/shelf-glass.mp3", angle: 290, volume: 0.18 },
];

const availableStems = stemSpecs.filter((stem) =>
  fs.existsSync(path.join(process.cwd(), "public", stem.src.slice(1))),
);
---

<button
  class="hero-ambience"
  type="button"
  data-hero-ambience
  data-audio-stems={JSON.stringify(availableStems)}
  aria-label="Start apothecary spatial ambience"
  aria-pressed="false"
>
  <span class="hero-ambience-bars" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </span>
</button>

<script>
  const controls = document.querySelectorAll("[data-hero-ambience]");

  controls.forEach((control) => {
    if (!(control instanceof HTMLButtonElement)) return;

    const stems = JSON.parse(control.dataset.audioStems || "[]");
    let context = null;
    let master = null;
    let buffers = new Map();
    let activeSources = [];
    let currentYaw = 210;
    let isPlaying = false;

    const setActive = (active) => {
      isPlaying = active;
      control.classList.toggle("is-playing", active);
      control.setAttribute("aria-pressed", active ? "true" : "false");
      control.setAttribute(
        "aria-label",
        active ? "Stop apothecary spatial ambience" : "Start apothecary spatial ambience",
      );
    };

    const shortestAngle = (from, to) => {
      const delta = ((to - from + 540) % 360) - 180;
      return delta;
    };

    const updateStemPosition = (stem) => {
      const delta = shortestAngle(currentYaw, stem.angle);
      const radians = delta * Math.PI / 180;
      const front = (Math.cos(radians) + 1) / 2;
      const pan = Math.max(-1, Math.min(1, Math.sin(radians) * 0.92));
      const volume = stem.baseVolume * (0.54 + front * 0.46);

      stem.panner.pan.setTargetAtTime(pan, context.currentTime, 0.08);
      stem.gain.gain.setTargetAtTime(volume, context.currentTime, 0.12);
    };

    const updateAllPositions = () => {
      if (!context) return;
      activeSources.forEach(updateStemPosition);
    };

    const loadBuffers = async () => {
      if (!context) return;

      await Promise.all(stems.map(async (stem) => {
        if (buffers.has(stem.src)) return;

        const response = await fetch(stem.src);
        const arrayBuffer = await response.arrayBuffer();
        buffers.set(stem.src, await context.decodeAudioData(arrayBuffer));
      }));
    };

    const createStem = (stem, index) => {
      const source = context.createBufferSource();
      const gain = context.createGain();
      const panner = context.createStereoPanner();

      source.buffer = buffers.get(stem.src);
      source.loop = true;
      gain.gain.value = 0.0001;
      source.connect(gain).connect(panner).connect(master);

      const activeStem = {
        ...stem,
        source,
        gain,
        panner,
        baseVolume: stem.volume,
      };

      updateStemPosition(activeStem);
      source.start(context.currentTime + index * 0.08);
      return activeStem;
    };

    const start = async () => {
      if (!stems.length) return;

      if (!context) {
        context = new AudioContext();
        master = context.createGain();
        master.gain.value = 0.0001;
        master.connect(context.destination);
      }

      await context.resume();
      await loadBuffers();

      activeSources.forEach((stem) => stem.source.stop());
      activeSources = stems.map(createStem);

      const now = context.currentTime;
      master.gain.cancelScheduledValues(now);
      master.gain.setValueAtTime(Math.max(master.gain.value, 0.0001), now);
      master.gain.exponentialRampToValueAtTime(0.86, now + 1.2);
      setActive(true);
    };

    const stop = () => {
      if (!context || !master) return;

      const now = context.currentTime;
      master.gain.cancelScheduledValues(now);
      master.gain.setValueAtTime(Math.max(master.gain.value, 0.0001), now);
      master.gain.exponentialRampToValueAtTime(0.0001, now + 0.65);
      window.setTimeout(() => {
        activeSources.forEach((stem) => stem.source.stop());
        activeSources = [];
      }, 720);
      setActive(false);
    };

    const onView = (event) => {
      currentYaw = event.detail?.yaw ?? currentYaw;
      updateAllPositions();
    };

    control.addEventListener("click", () => {
      if (isPlaying) {
        stop();
      } else {
        void start();
      }
    });

    window.addEventListener("apothecary:view", onView);

    document.addEventListener("astro:before-swap", () => {
      activeSources.forEach((stem) => stem.source.stop());
      window.removeEventListener("apothecary:view", onView);
      if (context) void context.close();
    }, { once: true });
  });
</script>
