---
import Base from "../layouts/Base.astro";
import Sparkline from "../components/Sparkline.astro";
import { getCollection } from "astro:content";

const skills = await getCollection("skills");
const bundles = await getCollection("bundles");

const recentSkills = skills
  .sort((a, b) => (b.data.auto_last_commit || "").localeCompare(a.data.auto_last_commit || ""))
  .slice(0, 9);

const activeSkills = skills
  .filter((s) => s.data.auto_activity.some((v) => v > 0))
  .sort((a, b) => {
    const sumA = a.data.auto_activity.reduce((s, v) => s + v, 0);
    const sumB = b.data.auto_activity.reduce((s, v) => s + v, 0);
    return sumB - sumA;
  })
  .slice(0, 6);

const bundleLabels: Record<string, string> = {
  "meeting-intelligence": "Meetings",
  communication: "Communication",
  research: "Research",
  "content-publishing": "Content",
  "personal-analytics": "Analytics",
  "thinking-strategy": "Thinking",
  "developer-tools": "Developer",
  "lab-consulting": "Lab",
};

const cabinetIcons: Record<string, string> = {
  "meeting-intelligence": "🜁",
  communication: "☿",
  research: "🝊",
  "content-publishing": "⊞",
  "personal-analytics": "☉",
  "thinking-strategy": "⚖",
  "developer-tools": "⚒",
  "lab-consulting": "🝆",
};

const cabinetColors: Record<string, string> = {
  "meeting-intelligence": "oklch(62% 0.13 78)",
  communication: "oklch(58% 0.09 186)",
  research: "oklch(52% 0.11 18)",
  "content-publishing": "oklch(56% 0.1 286)",
  "personal-analytics": "oklch(57% 0.1 318)",
  "thinking-strategy": "oklch(55% 0.1 142)",
  "developer-tools": "oklch(58% 0.11 55)",
  "lab-consulting": "oklch(53% 0.12 34)",
};
---

<Base title="Home">
  <section class="home-hero" aria-label="The Apothecary">
    <div class="home-hero-panel">
      <p class="hero-kicker">Est. 2025 · terminal formulary</p>
      <h1>The Apothecary</h1>
      <p class="state-line">
        {skills.length} practical preparations for Claude Code, cataloged by the work they help an agent perform.
      </p>

      <div class="hero-actions">
        <a href="/catalog" class="cta-card cta-primary">Browse the Catalog</a>
        <a href="https://github.com/glebis/claude-skills" target="_blank" class="cta-card cta-secondary">GitHub source</a>
      </div>
    </div>
  </section>

  <section class="quiet-panel">
    <div class="container recipe-strip">
      <div>
        <p class="section-label">Field note</p>
        <h2>Recipes an agent can actually follow</h2>
        <p style="color:var(--ink-light);font-size:1.08rem;line-height:1.65;max-width:60ch;margin-top:0.8rem;">
          Skills are reusable markdown instructions that extend <a href="https://docs.anthropic.com/en/docs/claude-code/skills" target="_blank" class="link">Claude Code</a> with specialized capabilities: meeting transcription, image generation, test-driven development, research workflows, and more. Each preparation packages a repeatable way of working.
        </p>
      </div>
      <div class="recipe-commands">
        <p class="mono" style="color:var(--ink-muted);font-size:0.72rem;">Install any preparation</p>
        <code class="install-cmd" style="font-size:0.8rem;">/plugin marketplace add glebis/claude-skills</code>
        <code class="install-cmd" style="font-size:0.8rem;color:var(--ink-muted);">/plugin install &lt;skill-name&gt;@glebis-skills</code>
      </div>
    </div>
  </section>

  <section class="container" style="padding-top:clamp(3rem,8vw,6rem);padding-bottom:clamp(3rem,8vw,6rem);">
    <div class="specimen-band">
      <aside class="specimen-note">
        <p class="section-label">Cabinet index</p>
        <h2>Eight drawers, sorted by the kind of work on the bench</h2>
        <p style="margin-top:0.85rem;">
          The catalog keeps the metaphor because it fits the object: compact instructions, dependencies, triggers, and provenance. Each cabinet is a working shelf rather than a category label.
        </p>
      </aside>

      <div class="cabinet-grid">
        {
          bundles
            .sort((a, b) => a.data.order - b.data.order)
            .map((bundle) => (
              <a href={`/bundles/${bundle.id}`} class="bundle-card" style={`--cabinet-color: ${cabinetColors[bundle.id] || "var(--accent)"}`}>
                <div style="display:flex;align-items:baseline;gap:0.75rem;margin-bottom:0.5rem;">
                  <span class="cabinet-icon">{cabinetIcons[bundle.id]}</span>
                  <span class="roman">{bundle.data.roman}</span>
                  <span class="bundle-name">{bundle.data.apothecary_name}</span>
                </div>
                <p class="card-description">{bundle.data.tagline}</p>
                <p class="card-meta">{bundle.data.skills.length} preparations</p>
              </a>
            ))
        }
      </div>
    </div>
  </section>

  <section class="quiet-panel">
    <div class="container">
      <div style="display:flex;justify-content:space-between;gap:2rem;align-items:end;margin-bottom:1.5rem;flex-wrap:wrap;">
        <div>
          <p class="section-label">Bench heat</p>
          <h2>Most Active</h2>
        </div>
        <p class="mono" style="color:var(--ink-muted);font-size:0.72rem;">Highest commit activity in the last 12 weeks</p>
      </div>
      <div class="catalog-grid">
        {
          activeSkills.map((skill) => (
            <a href={`/catalog/${skill.id}`} class="card activity-card">
              <div>
                <p class="card-title">{skill.data.name}</p>
                <p class="card-description" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                  {skill.data.tagline || skill.data.auto_description}
                </p>
                <p class="card-meta" style="margin-top:0.5rem;">
                  {skill.data.auto_activity.reduce((s, v) => s + v, 0)} commits · {bundleLabels[skill.data.bundle] || skill.data.bundle}
                </p>
              </div>
              <Sparkline data={skill.data.auto_activity} width={80} height={18} />
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="container" style="padding-top:clamp(3rem,7vw,5rem);padding-bottom:3rem;">
    <p class="section-label">Fresh labels</p>
    <h2 style="margin-bottom:0.45rem;">Recent Additions</h2>
    <p style="color:var(--ink-muted);font-size:0.9rem;margin-bottom:1.5rem;">Latest skills added or updated</p>
    <div class="catalog-grid">
      {
        recentSkills.map((skill) => (
          <a href={`/catalog/${skill.id}`} class="card">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.4rem;">
              <p class="card-title">{skill.data.name}</p>
              <span class="mono" style="font-size:0.55rem;color:var(--ink-dim);">{skill.data.auto_last_commit}</span>
            </div>
            <p class="card-description" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
              {skill.data.tagline || skill.data.auto_description}
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <div class="ornament"></div>

  <section class="container" style="padding-top:2rem;padding-bottom:3rem;">
    <p class="section-label">Complete shelf</p>
    <h2 style="margin-bottom:1.35rem;">All Preparations</h2>
    <div class="specimen-list">
      {
        skills
          .sort((a, b) => a.data.name.localeCompare(b.data.name))
          .map((skill) => (
            <a href={`/catalog/${skill.id}`} class="compact-link">
              <span class="compact-name mono" style="font-size:0.72rem;color:var(--ink-light);">{skill.data.name}</span>
              <span style="font-size:0.65rem;color:var(--ink-dim);">{bundleLabels[skill.data.bundle] || ""}</span>
            </a>
          ))
      }
    </div>
    <div style="text-align:center;margin-top:2rem;">
      <a href="/catalog" class="cta-card cta-primary" style="font-size:0.9rem;">Browse the Full Catalog</a>
    </div>
  </section>
</Base>

<style>
  .container > div > a[href^="/catalog/"]:hover {
    background: var(--bg-raised);
  }
</style>
