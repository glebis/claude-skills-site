---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const bundles = await getCollection("bundles");
const allSkills = await getCollection("skills");

const bundlesWithSkills = bundles
  .sort((a, b) => a.data.order - b.data.order)
  .map((bundle) => {
    const skills = allSkills.filter((s) => bundle.data.skills.includes(s.id));
    return { bundle, skills };
  });

const accentColors: Record<string, string> = {
  amber: "oklch(62% 0.13 78)",
  teal: "oklch(58% 0.09 186)",
  burgundy: "oklch(52% 0.11 18)",
  indigo: "oklch(56% 0.1 286)",
  violet: "oklch(57% 0.1 318)",
  green: "oklch(55% 0.1 142)",
  copper: "oklch(58% 0.11 55)",
  crimson: "oklch(53% 0.12 34)",
};
---

<Base title="Cabinets">
  <section class="container cabinet-index-page">
    <header class="cabinet-index-hero">
      <div>
        <p class="section-label">Cabinet wall</p>
        <h1>Cabinets</h1>
        <p class="state-line">
          Eight drawers for recurring agent work: meetings, communication, research, publishing, analytics, strategy, development, and lab operations.
        </p>
      </div>
      <div class="cabinet-index-plate" aria-label="Cabinet quick links">
        {bundlesWithSkills.map(({ bundle, skills }) => (
          <a
            href={`/bundles/${bundle.id}`}
            class="cabinet-index-drawer"
            style={`--cabinet-color: ${accentColors[bundle.data.accent_color] || "var(--accent)"}`}
          >
            <span>{bundle.data.roman}</span>
            <small>{skills.length}</small>
          </a>
        ))}
      </div>
    </header>

    <div class="cabinet-showcase">
      {
        bundlesWithSkills.map(({ bundle, skills }) => (
          <a
            href={`/bundles/${bundle.id}`}
            class="cabinet-card"
            style={`--cabinet-color: ${accentColors[bundle.data.accent_color] || "var(--accent)"}`}
          >
            <div class="cabinet-media">
              {bundle.data.hero_image && (
                <img src={bundle.data.hero_image} alt={bundle.data.apothecary_name} loading="eager" />
              )}
            </div>
            <div class="cabinet-content">
              <div class="cabinet-title-row">
                <span class="cabinet-roman">{bundle.data.roman}</span>
                <h2 class="cabinet-name">{bundle.data.apothecary_name}</h2>
              </div>
              <p class="cabinet-common-name">{bundle.data.name}</p>
              <p class="cabinet-tagline">{bundle.data.tagline}</p>
              <div class="cabinet-skills">
                {skills.map((s) => (
                  <span class="cabinet-skill-tag">{s.data.name}</span>
                ))}
              </div>
              <p class="card-meta">{skills.length} preparations cataloged</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Base>
