---
import Base from "../../layouts/Base.astro";
import Sparkline from "../../components/Sparkline.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const bundles = await getCollection("bundles");
  return bundles.map((bundle) => ({ params: { id: bundle.id }, props: { bundle } }));
}

const { bundle } = Astro.props;
const { Content } = await render(bundle);

const allSkills = await getCollection("skills");
const bundleSkills = allSkills.filter((s) => bundle.data.skills.includes(s.id));
const otherSkills = allSkills.filter(
  (s) => s.data.bundle === bundle.id && !bundle.data.skills.includes(s.id)
);
---

<Base title={bundle.data.apothecary_name}>
  <article class="container" style="padding-top:3rem;padding-bottom:3rem;">
    <a href="/bundles" class="back-link">← Back to Cabinets</a>

    <header class="skill-header">
      <div style="display:flex;align-items:baseline;gap:1rem;margin-bottom:0.5rem;">
        <span class="mono" style="color:var(--ink-dim);font-size:0.8rem;">{bundle.data.roman}</span>
        <h1 style="font-variant:small-caps;">{bundle.data.apothecary_name}</h1>
      </div>
      <p class="tagline">{bundle.data.tagline}</p>
    </header>

    {bundle.data.hero_image && (
      <img src={bundle.data.hero_image} alt={bundle.data.apothecary_name} class="hero-image" style="margin-bottom:2rem;" />
    )}

    <div class="skill-body" style="margin-bottom:2rem;">
      <Content />
    </div>

    <div class="ornament"></div>

    <h2 style="margin-bottom:1.5rem;">Preparations in this Cabinet</h2>
    <div class="catalog-grid">
      {
        bundleSkills
          .sort((a, b) => a.data.name.localeCompare(b.data.name))
          .map((skill) => (
            <a href={`/catalog/${skill.id}`} class="card">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.4rem;">
                <p class="card-title">{skill.data.name}</p>
                <Sparkline data={skill.data.auto_activity} />
              </div>
              <p class="card-description" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                {skill.data.tagline || skill.data.auto_description}
              </p>
            </a>
          ))
      }
    </div>
  </article>
</Base>
