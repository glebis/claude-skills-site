---
import Base from "../../layouts/Base.astro";
import Sparkline from "../../components/Sparkline.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const bundles = await getCollection("bundles");
  return bundles.map((bundle) => ({ params: { id: bundle.id }, props: { bundle } }));
}

const { bundle } = Astro.props;
const { Content } = await render(bundle);

const allSkills = await getCollection("skills");
const bundleSkills = allSkills.filter((s) => bundle.data.skills.includes(s.id));
const activeCount = bundleSkills.filter((s) => s.data.auto_activity.some((v) => v > 0)).length;
const commitCount = bundleSkills.reduce((sum, s) => sum + s.data.auto_activity.reduce((a, v) => a + v, 0), 0);

const accentColors: Record<string, string> = {
  amber: "oklch(62% 0.13 78)",
  teal: "oklch(58% 0.09 186)",
  burgundy: "oklch(52% 0.11 18)",
  indigo: "oklch(56% 0.1 286)",
  violet: "oklch(57% 0.1 318)",
  green: "oklch(55% 0.1 142)",
  copper: "oklch(58% 0.11 55)",
  crimson: "oklch(53% 0.12 34)",
};

const cabinetColor = accentColors[bundle.data.accent_color] || "var(--accent)";
---

<Base title={bundle.data.apothecary_name}>
  <article class="cabinet-detail-page" style={`--cabinet-color: ${cabinetColor}`}>
    <div class="container">
      <a href="/bundles" class="back-link">← Back to Cabinets</a>
    </div>

    <header class="cabinet-detail-hero">
      <div class="container cabinet-detail-layout">
        <div class="cabinet-detail-copy">
          <p class="section-label">{bundle.data.roman} · {bundle.data.name}</p>
          <h1>{bundle.data.apothecary_name}</h1>
          <p class="state-line">{bundle.data.tagline}</p>

          <div class="cabinet-ledger" aria-label="Cabinet summary">
            <span>{bundleSkills.length} preparations</span>
            <span>{activeCount} active</span>
            <span>{commitCount} recent commits</span>
          </div>
        </div>

        {bundle.data.hero_image && (
          <div class="cabinet-detail-image">
            <img src={bundle.data.hero_image} alt={bundle.data.apothecary_name} />
          </div>
        )}
      </div>
    </header>

    <section class="container cabinet-detail-body">
      <aside class="cabinet-detail-note">
        <p class="section-label">Cabinet note</p>
        <div class="skill-body">
          <Content />
        </div>
      </aside>

      <div>
        <p class="section-label">Preparations</p>
        <h2 style="margin-bottom:1.5rem;">In this Cabinet</h2>

        <div class="cabinet-skill-grid">
          {
            bundleSkills
              .sort((a, b) => a.data.name.localeCompare(b.data.name))
              .map((skill) => (
                <a href={`/catalog/${skill.id}`} class="card cabinet-skill-card">
                  {skill.data.hero_image && (
                    <div class="cabinet-skill-image">
                      <img src={skill.data.hero_image} alt="" loading="lazy" />
                    </div>
                  )}
                  <div>
                    <div style="display:flex;justify-content:space-between;align-items:center;gap:0.75rem;margin-bottom:0.4rem;">
                      <p class="card-title">{skill.data.name}</p>
                      <Sparkline data={skill.data.auto_activity} />
                    </div>
                    <p class="card-description" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                      {skill.data.tagline || skill.data.auto_description}
                    </p>
                  </div>
                </a>
              ))
          }
        </div>
      </div>
    </section>
  </article>
</Base>
